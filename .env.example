# DAGPulse environment variables
#
# Copy this file to .env and edit as needed.
#
# ── DAGPulse bridge configuration ─────────────────────────────────────────────
#
# The bridge server connects to HTND via native gRPC and exposes a WebSocket
# endpoint (/ws) that the browser connects to.
#
# In development the Vite dev-server proxy forwards /dagpulse/ws to the bridge.
# In production nginx proxies /dagpulse/ws to the bridge.
#
# HTND gRPC host/port (used by the bridge server, not the browser)
# HTND_HOST=localhost
# HTND_PORT=42420
#
# Port the bridge server listens on
# BRIDGE_PORT=8765
