# DAGPulse environment variables
#
# Copy this file to .env and edit as needed.
#
# ── gRPC-web endpoint ──────────────────────────────────────────────────────────
#
# In development the Vite dev-server proxy forwards /protowire.RPC/* requests to
# this address so the browser never hits CORS restrictions.
#
# Default: the HTND node's standard gRPC port on localhost
# VITE_RPC_HOST=http://localhost:16110
#
# If your HTND node does not have gRPC-web support built in (most stock builds),
# run grpcwebproxy in front of it first:
#
#   grpcwebproxy \
#     --backend_addr=localhost:16110 \
#     --allow_all_origins \
#     --run_tls_server=false \
#     --server_http_debug_port=8080
#
# Then set:
# VITE_RPC_HOST=http://localhost:8080
#
# ── Production / nginx deployment ─────────────────────────────────────────────
#
# When served through nginx the app uses the same origin as the website, so
# VITE_RPC_HOST should be left empty (same-origin) or set to the public URL:
#
# VITE_RPC_HOST=https://your-htnd-dashboard.example.com
